{
  "name": "agent-scorecard",
  "version": "0.2.0",
  "type": "module",
  "description": "Deterministic configuration audit for monday.com Agent Builder agents",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "agent-scorecard": "./dist/cli.js"
  },
  "files": [
    "dist",
    "schemas"
  ],
  "scripts": {
    "build": "tsc",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prettier:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prettier:fix": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "validate:schema": "node scripts/validate-fixtures.mjs",
    "verify": "npm run lint && npm run prettier:check && npm test && npm run validate:schema"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^3.2.4",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
