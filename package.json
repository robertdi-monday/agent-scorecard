{
  "name": "agent-scorecard",
  "version": "2.0.0",
  "type": "module",
  "description": "Deterministic configuration audit for monday.com Agent Builder agents",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "agent-scorecard": "./dist/cli.js",
    "agent-scorecard-mcp": "./dist/mcp/server.js"
  },
  "files": [
    "dist",
    "schemas"
  ],
  "scripts": {
    "build": "tsc",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prettier:check": "prettier --check \"src/**/*.{ts,tsx}\" \"tests/**/*.ts\"",
    "prettier:fix": "prettier --write \"src/**/*.{ts,tsx}\" \"tests/**/*.ts\"",
    "mcp": "tsx src/mcp/server.ts",
    "mcp:http": "tsx src/mcp/http-server.ts",
    "build:app": "vite build --config vite.config.app.ts",
    "validate:schema": "node scripts/validate-fixtures.mjs",
    "gen:spec": "tsx scripts/gen-spec.ts",
    "gen:spec:check": "tsx scripts/gen-spec.ts --check",
    "provision:hanna": "tsx scripts/provision-hanna-test-agent.ts",
    "verify": "npm run lint && npm run prettier:check && npm test && npm run validate:schema && npm run gen:spec:check"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^3.2.4",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "monday-sdk-js": "^0.5.8",
    "prettier": "^3.5.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^7.3.3",
    "vitest": "^3.1.4"
  }
}
