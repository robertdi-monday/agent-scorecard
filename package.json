{
  "name": "agent-scorecard",
  "version": "0.1.0",
  "type": "module",
  "description": "Deterministic configuration audit for monday.com Agent Builder agents",
  "bin": {
    "agent-scorecard": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prettier:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prettier:fix": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
