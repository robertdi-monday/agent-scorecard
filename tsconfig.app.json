{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist-app",
    "rootDir": "src",
    "declaration": false,
    "sourceMap": true
  },
  "include": ["src/app"],
  "exclude": ["node_modules"]
}
